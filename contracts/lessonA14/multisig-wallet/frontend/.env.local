
# ============ 合约地址配置 ============
# 部署合约后，将合约地址填入对应网络
# Localhost 网络合约地址
# NEXT_PUBLIC_CONTRACT_ADDRESS_LOCALHOST=

# Sepolia 测试网合约地址
NEXT_PUBLIC_CONTRACT_ADDRESS_SEPOLIA=https://sepolia.infura.io/v3/xxxxxxxxx

# 主网合约地址
# NEXT_PUBLIC_CONTRACT_ADDRESS_MAINNET=

# ============代理合约地址配置 ============
# 如果已部署合约，则填入代理合约的address
NEXT_PUBLIC_CONTRACT_ADDRESS_SEPOLIA=xxxxxxxxx

